# Port of the node server
PORT=3900

# Url of mongodb server / db name
MONGODB_URL=mongodb://0.0.0.0:27017/sae501
# If mongodb docker
# MONGODB_URL=mongodb://mongo:27017/sae501
# If nodejs docker + local mongodb
# MONGODB_URL=mongodb://host.docker.internal:27017/sae501
# If mongodb atlas
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/appdb

# For security purpose you can set a string
# this way everybody is not able to access admin
ADMIN_SUFFIX=
IS_ESLINT_AUTO_FIX_ENABLED=false
